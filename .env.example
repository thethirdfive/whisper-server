# ============================================================================
# whisper-server 环境变量配置
# 复制这个文件为 .env 并填入你的值
# ============================================================================

# === 应用基础 ===
APP_ENV=production              # development / production
APP_SECRET_KEY=changeme_use_openssl_rand_hex_32   # openssl rand -hex 32
APP_PUBLIC_URL=https://whisper.abowk.cn
APP_DEFAULT_LOCALE=zh-CN        # zh-CN / en-US
APP_TIMEZONE=Asia/Shanghai

# === 鉴权（首次启动会自动创建管理员）===
ADMIN_USERNAME=ethan
ADMIN_EMAIL=asecondfive@gmail.com
ADMIN_DISPLAY_NAME=Ethan
# 生成方式：
#   docker run --rm python:3.11 python -c "import bcrypt;print(bcrypt.hashpw(b'你的密码', bcrypt.gensalt(12)).decode())"
# ⚠️ 必须用单引号包裹！bcrypt 哈希含 $，否则会被 docker compose env_file 当变量插值，导致哈希损坏、登录恒失败。
ADMIN_PASSWORD_BCRYPT='$2b$12$EXAMPLE_REPLACE_WITH_YOUR_BCRYPT_HASH'
SESSION_LIFETIME_DAYS=30

# === 数据库 ===
DATABASE_URL=sqlite:////data/whisper/db/whisper.db

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === WhisperX ===
# 注：以下大多数运营类配置(模型/精度/上传限制/通知/看守目录/日志级别…)现在也能在
# 「设置」页在线修改 —— 数据库里的值会在运行时覆盖这里的 .env 默认值。
# 但 HF_TOKEN / APP_SECRET_KEY / 密码等敏感项只在 .env 配置，页面只读打码。
#
# 说话人分离按【每场会议】在上传时选：
#   channels 按声道拆分(双声道/每人一麦，离线可用) | auto/count 同声道多人(需下面的 gated 模型)
#
# HuggingFace token（接受了 pyannote/speaker-diarization-community-1 条款后生成）
# auto/count 模式必需；验证：docker compose exec worker python scripts/check_diarization.py
HF_TOKEN=hf_REPLACE_WITH_YOUR_TOKEN
# 国内镜像：huggingface.co 直连常报 SSL EOF（GFW），用 hf-mirror.com 拉模型（境外服务器可留空）
HF_ENDPOINT=https://hf-mirror.com
# === worker 专用 HF 网络（覆盖上面的 HF_ENDPOINT，仅 worker；见 docker-compose.yml）===
# 镜像不给下 gated（pyannote）权重文件，故 worker 需直连真 huggingface.co。
# 有本机代理（如 mihomo）时填这两项让 worker 经代理直连；没有就留空，自动回退 hf-mirror。
WORKER_HF_ENDPOINT=https://huggingface.co
WORKER_HF_PROXY=http://host.docker.internal:7890
WHISPER_MODEL=large-v3
DIARIZE_MODEL=pyannote/speaker-diarization-community-1
WHISPER_DEVICE=cuda             # cuda / cpu
WHISPER_COMPUTE_TYPE=int8       # int8（省显存）/ float16（更准）
WHISPER_MAX_PROMPT_TERMS=80     # initial_prompt 最多带几个术语

# === Google Drive（Phase 2 启用）===
GDRIVE_CREDENTIALS_JSON=/data/whisper/gdrive_creds.json
GDRIVE_ROOT_FOLDER_ID=18uzn-GtK4gFqbqAsnh6yjl6XvHZPegQp
GDRIVE_MEETING_FOLDER_ID=1d0F4_8eiVkvQNgNgQKGKLO4nNakiVRBX
GDRIVE_INTERVIEW_FOLDER_ID=1UZ6kX7iubNukwb8c48jlf4HjFonMo-yx
GDRIVE_TRAINING_FOLDER_ID=153HhKave8uAxIyH223GVeVSDzw2rzNxR

# === 通知（可选）===
BARK_KEY=                       # https://bark.day.app/ 推送到 iPhone

# === 上传限制 ===
UPLOAD_MAX_SIZE_MB=4096
UPLOAD_ALLOWED_AUDIO=m4a,mp3,wav,flac,aac,ogg,opus,aif,aiff,wma
UPLOAD_ALLOWED_VIDEO=mp4,mov,mkv,avi,flv,webm,m4v,mpeg,3gp

# === Watch folder（Phase 4 启用）===
WATCH_FOLDER_ENABLED=false
WATCH_FOLDER_PATH=/data/whisper/inbox
WATCH_FOLDER_SCAN_INTERVAL_SEC=60

# === 备份 ===
BACKUP_RETENTION_DAYS=30
BACKUP_CRON_SCHEDULE='0 3 * * *'  # 每天凌晨 3 点（含空格，必须加引号，否则 source .env 会报错）

# === 日志 ===
LOG_LEVEL=INFO                  # DEBUG / INFO / WARNING / ERROR
LOG_FORMAT=json                 # json / text

# ============================================================================
# === 双盘分层存储（host 路径，bind mount 用）===
# 部署前先跑: bash scripts/setup-storage.sh 创建所有目录
# ============================================================================

# NVMe 盘（速度敏感）—— 放 SQLite / 模型缓存 / Word 产物
HOST_DATA_DIR=/data/whisper

# HDD 盘（大文件）—— 放原音频/视频 / Watch folder / DB 备份
HOST_BULK_DIR=/mnt/data/whisper

# 端口绑定地址：127.0.0.1=仅本机（公网走 frpc）；0.0.0.0=同时开放局域网访问
APP_BIND_HOST=127.0.0.1
